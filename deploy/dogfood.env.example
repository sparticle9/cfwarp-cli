# Copy to deploy/.env (or another env file passed to docker compose --env-file).

CFWARP_IMAGE=ghcr.io/sparticle9/cfwarp-cli:latest
CFWARP_WIREGUARD_PORT=16080
CFWARP_MASQUE_PORT=16081
CFWARP_WIREGUARD_STATE_DIR=/home/cfwarp/.local/state/cfwarp-cli
CFWARP_MASQUE_STATE_DIR=/home/cfwarp/.local/state/cfwarp-cli
CFWARP_LOG_LEVEL=info
# Used only by the optional canary trace services.
TRACE_INTERVAL_SECONDS=60
