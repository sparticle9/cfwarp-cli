#!/bin/bash
set -euo pipefail

log_dir={{ dogfood_observer_log_dir | quote }}
mkdir -p "$log_dir"
log_file="$log_dir/probe.log"
trace_url="https://www.cloudflare.com/cdn-cgi/trace"
google_url="https://www.google.com/generate_204"

probe() {
  local name="$1"
  local port="$2"
  local url="$3"
  local kind="$4"
  local tmp_body
  tmp_body="$(mktemp)"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  local metrics rc http_code time_total time_connect time_starttransfer size_download warp colo ip
  if metrics=$(curl -fsS --max-time {{ dogfood_probe_timeout_seconds | int }} \
      --proxy "socks5h://127.0.0.1:${port}" \
      -o "$tmp_body" \
      -w 'http_code=%{http_code} time_total=%{time_total} time_connect=%{time_connect} time_starttransfer=%{time_starttransfer} size_download=%{size_download}' \
      "$url" 2>/dev/null); then
    rc=0
  else
    rc=$?
    metrics="http_code=000 time_total=-1 time_connect=-1 time_starttransfer=-1 size_download=0"
  fi

  http_code="$(awk '{for (i=1;i<=NF;i++) if ($i ~ /^http_code=/) {sub(/^http_code=/, "", $i); print $i}}' <<<"$metrics")"
  time_total="$(awk '{for (i=1;i<=NF;i++) if ($i ~ /^time_total=/) {sub(/^time_total=/, "", $i); print $i}}' <<<"$metrics")"
  time_connect="$(awk '{for (i=1;i<=NF;i++) if ($i ~ /^time_connect=/) {sub(/^time_connect=/, "", $i); print $i}}' <<<"$metrics")"
  time_starttransfer="$(awk '{for (i=1;i<=NF;i++) if ($i ~ /^time_starttransfer=/) {sub(/^time_starttransfer=/, "", $i); print $i}}' <<<"$metrics")"
  size_download="$(awk '{for (i=1;i<=NF;i++) if ($i ~ /^size_download=/) {sub(/^size_download=/, "", $i); print $i}}' <<<"$metrics")"

  warp=""
  colo=""
  ip=""
  if [ "$kind" = "trace" ] && [ -s "$tmp_body" ]; then
    warp="$(awk -F= '/^warp=/{print $2}' "$tmp_body" | tail -n1)"
    colo="$(awk -F= '/^colo=/{print $2}' "$tmp_body" | tail -n1)"
    ip="$(awk -F= '/^ip=/{print $2}' "$tmp_body" | tail -n1)"
  fi

  printf '{"ts":"%s","name":"%s","kind":"%s","port":%s,"rc":%s,"http_code":"%s","time_total":"%s","time_connect":"%s","time_starttransfer":"%s","size_download":"%s","warp":"%s","colo":"%s","ip":"%s"}\n' \
    "$ts" "$name" "$kind" "$port" "$rc" "$http_code" "$time_total" "$time_connect" "$time_starttransfer" "$size_download" "$warp" "$colo" "$ip" >> "$log_file"

  rm -f "$tmp_body"
}

probe wireguard {{ cfwarp_wireguard_port | int }} "$trace_url" trace
probe masque {{ cfwarp_masque_port | int }} "$trace_url" trace
probe wireguard {{ cfwarp_wireguard_port | int }} "$google_url" google204
probe masque {{ cfwarp_masque_port | int }} "$google_url" google204

printf '{"ts":"%s","kind":"service","service":"%s","status":"%s"}\n' \
  "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  {{ singbox_service_name | quote }} \
  "$(systemctl is-active {{ singbox_service_name | quote }} 2>/dev/null || true)" >> "$log_file"
